# ════════════════════════════════════════════════════════════════════════════
# Encrypted P2P Chat — Environment Configuration
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=production          # development | staging | production
DEBUG=false

# ── CRITICAL: Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_SECRET

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD

# ── WebAuthn (MUST match the domain users visit) ──────────────────────────────
# Docker/nginx quick start: http://localhost
# Vite local dev frontend: http://localhost:5173
# For production: your actual domain, e.g. chat.example.com
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Crypt
WEBAUTHN_ORIGIN=http://localhost,http://localhost:5173

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost,http://localhost:5173

# ── Vite dev server proxy ─────────────────────────────────────────────────────
# Defaults to Docker/Nginx at http://localhost. Use http://localhost:8000 only
# when running the backend directly on the host.
VITE_DEV_PROXY_TARGET=http://localhost

# ── Cookie Security ────────────────────────────────────────────────────────────
# Set to true in production with HTTPS
COOKIE_SECURE=false
